{
  "name": "kronos-cli",
  "version": "0.0.5",
  "description": "Kronos CLI - assistente de terminal com IA",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "node -e \"import('node:fs').then(fs=>fs.rmSync('dist',{recursive:true,force:true}))\"",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build",
    "pack:check": "npm pack --dry-run"
  },
  "keywords": [
    "cli",
    "ai",
    "terminal",
    "linux",
    "openrouter",
    "ollama"
  ],
  "author": "Lesenechal",
  "license": "MIT",
  "type": "module",
  "bin": {
    "kronos": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "inquirer": "^13.3.2",
    "ora": "^8.0.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
